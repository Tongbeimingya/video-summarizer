DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Whisper 模型大小: tiny/base/small/medium/large-v3
WHISPER_MODEL=tiny

# 视觉增强模式（Vision Mode）
# 支持多模态的模型，如 deepseek-vl2
DEEPSEEK_VISION_MODEL=deepseek-vl2

# 关键帧提取间隔（秒），默认10秒
VISION_INTERVAL=10

# 场景变化检测阈值（0-1），越小越敏感
VISION_SCENE_THRESHOLD=0.3

# HuggingFace 镜像（国内加速）
# HF_ENDPOINT=https://hf-mirror.com
